<% content_for :page_title, "Вход | Pixel Pulse" %>
            <div class="form-container">
                <h2>🎮 ВХОД В ИГРУ 🎮</h2>
                <form id="loginForm">
                    <div class="form-group">
                        <label>👤 ИМЯ ПОЛЬЗОВАТЕЛЯ</label>
                        <input type="text" id="loginUsername" placeholder="PLAYER1" required>
                    </div>
                    <div class="form-group">
                        <label>🔒 ПАРОЛЬ</label>
                        <input type="password" id="loginPassword" placeholder="******" required>
                    </div>
                    <button type="submit" class="arcade-button">➡ ВОЙТИ</button>
                    <div class="form-footer">
                        Нет аккаунта? <a href="/registration" id="registerMockLink">ЗАРЕГИСТРИРОВАТЬСЯ →</a>
                    </div>
                </form>

                <div class="pacman-canvas-container">
                    <canvas id="pacmanCanvas" width="400" height="80"></canvas>
                </div>
                <div class="success-message" id="successMessage">✅ ДОБРО ПОЖАЛОВАТЬ! ✅</div>
            </div>
            
                <script>
        (function() {
            // ========== 1. АНИМАЦИЯ ПАКМАНА (успешный вход) ==========

            const form = document.getElementById('loginForm');
            const canvas = document.getElementById('pacmanCanvas');
            const ctx = canvas.getContext('2d');
            const successMsgDiv = document.getElementById('successMessage');

            let animationActive = false;
            let animationFrame = null;
            let posX = 0;
            let dots = [];

            let pacmanMouthAngle = 0;
            let mouthDirection = 1;
            let animationCompleted = false;
            let smileFrame = 0;

            const PACMAN_RADIUS = 20;
            const DOT_RADIUS = 3;
            const DOT_COUNT = 12;
            const START_X = 30;
            const END_X = canvas.width - 30;
            const STEP = 2;


            function initDots() {
                dots = [];
                const spacing = (canvas.width - 80) / (DOT_COUNT - 1);
                for (let i = 0; i < DOT_COUNT; i++) {

                    dots.push({ x: 40 + i * spacing, y: canvas.height / 2, active: true });
                }
            }

            function drawPacman(x, y, angle) {
                ctx.save();

                ctx.translate(x, y);
                ctx.beginPath();
                ctx.arc(0, 0, PACMAN_RADIUS, angle, 2 * Math.PI - angle);
                ctx.lineTo(0, 0);
                ctx.fillStyle = '#ff0';

                ctx.fill();
                ctx.restore();
            }

            function drawSmile(x, y) {
                ctx.beginPath();
                ctx.arc(x, y, PACMAN_RADIUS * 0.7, 0.1 * Math.PI, 0.9 * Math.PI, false);
                ctx.strokeStyle = '#000';
                ctx.lineWidth = 3;
                ctx.stroke();

                ctx.beginPath();
                ctx.arc(x - 8, y - 5, 3, 0, 2 * Math.PI);
                ctx.fillStyle = '#000';
                ctx.fill();
            }


            function animatePacman() {
                if (!animationActive) return;
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                for (let dot of dots) {
                    if (dot.active) {

                        ctx.beginPath();
                        ctx.arc(dot.x, dot.y, DOT_RADIUS, 0, 2 * Math.PI);
                        ctx.fillStyle = '#fff';
                        ctx.fill();
                    }

                }
                if (!animationCompleted) {
                    posX += STEP;
                    if (posX > END_X) {
                        posX = END_X;

                        animationCompleted = true;
                        for (let dot of dots) dot.active = false;
                    } else {
                        for (let dot of dots) {
                            if (dot.active && Math.abs(dot.x - posX) < PACMAN_RADIUS + DOT_RADIUS) {

                                dot.active = false;

                            }
                        }
                    }
                    pacmanMouthAngle += 0.05 * mouthDirection;
                    if (pacmanMouthAngle > 0.7) mouthDirection = -1;

                    if (pacmanMouthAngle < 0.2) mouthDirection = 1;
                    const mouth = 0.2 + pacmanMouthAngle * 0.3;
                    drawPacman(posX, canvas.height / 2, mouth);
                } else {
                    drawPacman(posX, canvas.height / 2, 0.1);

                    drawSmile(posX, canvas.height / 2);
                    successMsgDiv.style.display = 'block';
                    if (smileFrame === 0) {
                        setTimeout(() => {
                            cancelAnimationFrame(animationFrame);

                            animationActive = false;
                            setTimeout(() => {
                                alert(`✨ Добро пожаловать, ${localStorage.getItem('registeredUser') || 'игрок'}! Вы успешно вошли в аркаду. ✨`);
                                form.reset();
                                canvas.style.display = 'none';
                                successMsgDiv.style.display = 'none';

                            }, 1500);
                        }, 1500);
                        smileFrame = 1;
                    }
                }

                if (animationActive) {
                    animationFrame = requestAnimationFrame(animatePacman);
                }
            }


            function startPacmanAnimation() {
                if (animationActive) return;
                canvas.style.display = 'block';
                successMsgDiv.style.display = 'none';
                posX = START_X;
                animationCompleted = false;

                smileFrame = 0;
                pacmanMouthAngle = 0;
                mouthDirection = 1;
                initDots();
                animationActive = true;

                animatePacman();
            }

            // Валидация формы входа
            form.addEventListener('submit', function(e) {

                e.preventDefault();
                const username = document.getElementById('loginUsername').value.trim();
                const password = document.getElementById('loginPassword').value;
                const registeredUser = localStorage.getItem('registeredUser');

                if (!registeredUser) {
                    alert('❌ Нет зарегистрированных пользователей. Пожалуйста, зарегистрируйтесь сначала.');
                    return;
                }
                if (registeredUser === username) {
                    startPacmanAnimation();

                } else {
                    alert(`❌ Неверное имя пользователя. Зарегистрированный пользователь: ${registeredUser}`);
                }
            });


            canvas.width = 400;
            canvas.height = 80;
            canvas.style.display = 'none';
            initDots();

        })();
        
        </script>
