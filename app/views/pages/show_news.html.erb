
            <article class="news-article">
                <!-- Кнопка назад -->
                <div class="back-button">
                    <a href="/news" class="arcade-link" id="backToNewsBtn">◀ НАЗАД К НОВОСТЯМ</a>
                </div>

                <!-- Заголовок новости -->
                <h1 class="article-title glitch" data-text="<% @article_item.title %>"><%= @article_item.title %></h1>

                <!-- Мета-информация -->
                <div class="article-meta">
                    <span class="article-date">📅 <%= @article_item.date.strftime("%d.%m.%Y") %></span>
                    <span class="article-author">✍️ Автор: <%= @article_item.author %></span>
                    <span class="article-comments-count">💬 ... комментариев</span>
                </div>
<%= sanitize @article_item.content %>

                <!-- Блок комментариев -->
                <div class="comments-section">
                    <h2 class="section-title blink">💬 КОММЕНТАРИИ</h2>

                    <!-- Форма добавления комментария -->
                    <div class="comment-form">
                        <h3>ДОБАВИТЬ КОММЕНТАРИЙ</h3>
                        <form id="commentForm">
                            <div class="form-group">
                                <label>👤 ИМЯ</label>
                                <input type="text" id="commentName" placeholder="RETRO_GAMER" required>
                            </div>
                            <div class="form-group">
                                <label>💬 КОММЕНТАРИЙ</label>
                                <textarea id="commentText" rows="4" placeholder="Введите ваш комментарий..." required></textarea>
                            </div>
                            <button type="submit" class="arcade-button">➡ ОТПРАВИТЬ</button>
                        </form>
                    </div>

                    <!-- Список комментариев -->
                    <div class="comments-list" id="commentsList">
                        <!-- Комментарии будут загружены из localStorage или показаны примеры -->
                    </div>
                </div>
            </article>

    <script type="module">
            // ========== 4. СИСТЕМА КОММЕНТАРИЕВ (localStorage) ==========
            const STORAGE_KEY = 'news_comments_1';

            function loadComments() {
                const saved = localStorage.getItem(STORAGE_KEY);
                if (saved) return JSON.parse(saved);
                return [
                    { id: 1, name: 'HOLLOW_FAN', text: 'Офигенно! Жду с нетерпением!', date: '21.03.2026 14:30', avatar: '👤' },
                    { id: 2, name: 'METROID_LOVER', text: 'Надеюсь, будет так же атмосферно, как Hollow Knight', date: '21.03.2026 15:45', avatar: '👤' }
                ];
            }

            function saveComments(comments) {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(comments));
            }

            function escapeHtml(str) {
                return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
            }

            function renderComments() {
                const comments = loadComments();
                const container = document.getElementById('commentsList');
                if (!container) return;
                if (comments.length === 0) {
                    container.innerHTML = '<div class="no-comments">🤖 ПОКА НЕТ КОММЕНТАРИЕВ. БУДЬ ПЕРВЫМ!</div>';
                } else {
                    container.innerHTML = comments.map(comment => `
                        <div class="comment-item" data-id="${comment.id}">
                            <div class="comment-avatar">${comment.avatar || '👤'}</div>
                            <div class="comment-content">
                                <div class="comment-header">
                                    <span class="comment-name">${escapeHtml(comment.name)}</span>
                                    <span class="comment-date">📅 ${comment.date}</span>
                                </div>
                                <div class="comment-text">${escapeHtml(comment.text)}</div>
                                <button class="comment-delete" data-id="${comment.id}">🗑 УДАЛИТЬ</button>
                            </div>
                        </div>
                    `).join('');
                }
                // Обновляем счётчик комментариев в мета-информации
                const commentsCountSpan = document.querySelector('.article-comments-count');
                if (commentsCountSpan) {
                    commentsCountSpan.textContent = `💬 ${comments.length} комментариев`;
                }
                // Добавляем обработчики удаления
                document.querySelectorAll('.comment-delete').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        const id = parseInt(btn.dataset.id);
                        deleteComment(id);
                    });
                });
            }

            function addComment(name, text) {
                const comments = loadComments();
                const newComment = {
                    id: Date.now(),
                    name: name.substring(0, 20),
                    text: text.substring(0, 500),
                    date: new Date().toLocaleString('ru-RU'),
                    avatar: '👤'
                };
                comments.unshift(newComment);
                saveComments(comments);
                renderComments();
            }

            function deleteComment(id) {
                let comments = loadComments();
                comments = comments.filter(c => c.id !== id);
                saveComments(comments);
                renderComments();
            }

            // Обработчик формы комментария
            const commentForm = document.getElementById('commentForm');
            if (commentForm) {
                commentForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    const nameInput = document.getElementById('commentName');
                    const textInput = document.getElementById('commentText');
                    const name = nameInput.value.trim();
                    const text = textInput.value.trim();
                    if (!name || !text) {
                        alert('❌ Заполните оба поля!');
                        return;
                    }
                    addComment(name, text);
                    nameInput.value = '';
                    textInput.value = '';
                    document.body.style.backgroundColor = '#0f0';
                    setTimeout(() => document.body.style.backgroundColor = '#000', 100);
                });
            }

            // Инициализация комментариев
            renderComments();
    </script>

